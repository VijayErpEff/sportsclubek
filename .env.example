# ===========================================
# LevelUP Sports — Environment Variables
# Copy this file to .env.local and fill in values
# ===========================================

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console Verification
# Get from: https://search.google.com/search-console → HTML tag method
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code

# Bing Webmaster Tools Verification
# Get from: https://www.bing.com/webmasters → HTML tag method
NEXT_PUBLIC_BING_SITE_VERIFICATION=your-verification-code
